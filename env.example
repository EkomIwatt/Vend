# Copy this to .env.local and fill in real values.
# .env.local is gitignored — never commit it.

# === Supabase ===
# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — same page, under "Project API keys".
# WARNING: This key bypasses Row Level Security. Server-side only. Never expose
# to the browser. Never prefix with NEXT_PUBLIC. Never log it. We use it to
# create/delete auth users from the signup API route.
SUPABASE_SERVICE_ROLE_KEY=

# === Squad ===
# From sandbox.squadco.com → Merchant Settings → API & Webhook
# Server-side only — never prefix with NEXT_PUBLIC.
SQUAD_SECRET_KEY=
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com

# === App ===
# Base URL where this app is reachable. Used to build payment links + QR codes.
# Local dev: http://localhost:3000
# Vercel: leave blank — VERCEL_URL is auto-populated.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Gemini (Phase 3) — get a free key at https://aistudio.google.com/app/apikey ===
GEMINI_API_KEY=

# === Resend (Phase 4) ===
RESEND_API_KEY=
# The verified sender (must be on a domain you've verified in Resend).
RESEND_FROM_EMAIL=receipts@yourdomain.com

